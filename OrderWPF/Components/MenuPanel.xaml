<UserControl
    x:Class="OrderWPF.Components.MenuPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:OrderWPF.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    FontFamily="Yu Gothic UI, Meiryo UI, Microsoft JhengHei UI, sans-serif"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="SumiBlackBrush"   Color="#1C1C1E"/>
        <SolidColorBrush x:Key="InkGrayBrush"     Color="#6E6B66"/>
        <SolidColorBrush x:Key="LineGrayBrush"    Color="#D8D2C8"/>
        <SolidColorBrush x:Key="ChikuGreenBrush"  Color="#4A6741"/>
        <SolidColorBrush x:Key="BambooCreamBrush" Color="#F7F4EF"/>
        <SolidColorBrush x:Key="AccentGoldBrush"  Color="#B8960C"/>

        <!-- 表頭文字 -->
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource InkGrayBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 明細列：偶數行底色 -->
        <Style x:Key="ItemRow" TargetType="Border">
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F4F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 表頭 -->
            <RowDefinition Height="*"/>      <!-- 明細列 -->
        </Grid.RowDefinitions>

        <!-- ════════════════════
             表頭
        ════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BambooCreamBrush}"
                Padding="24,10"
                BorderBrush="{StaticResource LineGrayBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="72"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="品　項"
                           Style="{StaticResource HeaderText}"/>
                <TextBlock Grid.Column="1"
                           Text="單　價"
                           Style="{StaticResource HeaderText}"
                           HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="2"
                           Text="數量"
                           Style="{StaticResource HeaderText}"
                           HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3"
                           Text="小　計"
                           Style="{StaticResource HeaderText}"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- ════════════════════
             訂單明細列
        ════════════════════ -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding OrderItems}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ItemRow}"
                            BorderBrush="{StaticResource LineGrayBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="72"/>
                            </Grid.ColumnDefinitions>

                            <!-- 品項名稱 (左側加細綠線點綴) -->
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Width="2"
                                        Height="14"
                                        Background="{StaticResource ChikuGreenBrush}"
                                        CornerRadius="1"
                                        Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="13"
                                           Foreground="{StaticResource SumiBlackBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- 單價 -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Price, StringFormat=¥{0}}"
                                       FontSize="12"
                                       Foreground="{StaticResource InkGrayBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>

                            <!-- 數量 -->
                            <Border Grid.Column="2"
                                    Width="32" Height="24"
                                    Background="#EEF2ED"
                                    CornerRadius="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding Count}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ChikuGreenBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- 小計 -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Total, StringFormat=¥{0}}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGoldBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
