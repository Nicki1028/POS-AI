<Window
    x:Class="OrderWPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:OrderWPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
    Title="御膳 · POS"
    Width="1200"
    Height="720"
    Background="#F7F4EF"
    FontFamily="Yu Gothic UI, Meiryo UI, Microsoft JhengHei UI, sans-serif"
    mc:Ignorable="d">

    <Window.Resources>

        <!-- ═══════════════════════════════════════════
             色彩定義 Color Tokens
        ═══════════════════════════════════════════ -->
        <Color x:Key="WashiWhite">#F7F4EF</Color>
        <Color x:Key="SumiBlack">#1C1C1E</Color>
        <Color x:Key="ChikuGreen">#4A6741</Color>
        <Color x:Key="ChikuGreenLight">#6B8F62</Color>
        <Color x:Key="BambooCream">#E8E0D0</Color>
        <Color x:Key="InkGray">#6E6B66</Color>
        <Color x:Key="LineGray">#D8D2C8</Color>
        <Color x:Key="AccentGold">#B8960C</Color>

        <SolidColorBrush x:Key="WashiWhiteBrush" Color="#F7F4EF"/>
        <SolidColorBrush x:Key="SumiBlackBrush" Color="#1C1C1E"/>
        <SolidColorBrush x:Key="ChikuGreenBrush" Color="#4A6741"/>
        <SolidColorBrush x:Key="ChikuGreenLightBrush" Color="#6B8F62"/>
        <SolidColorBrush x:Key="BambooCreamBrush" Color="#E8E0D0"/>
        <SolidColorBrush x:Key="InkGrayBrush" Color="#6E6B66"/>
        <SolidColorBrush x:Key="LineGrayBrush" Color="#D8D2C8"/>
        <SolidColorBrush x:Key="AccentGoldBrush" Color="#B8960C"/>
        <SolidColorBrush x:Key="PanelBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#EEF2ED"/>

        <!-- ═══════════════════════════════════════════
             CheckBox 樣式
        ═══════════════════════════════════════════ -->
        <Style x:Key="JapaneseCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource SumiBlackBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CheckBorder"
                                    Width="16" Height="16"
                                    BorderBrush="{StaticResource LineGrayBrush}"
                                    BorderThickness="1.5"
                                    Background="Transparent"
                                    CornerRadius="2">
                                <TextBlock x:Name="CheckMark"
                                           Text="✓"
                                           FontSize="11"
                                           Foreground="{StaticResource ChikuGreenBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource ChikuGreenBrush}"/>
                                <Setter TargetName="CheckBorder" Property="Background" Value="#EEF2ED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════
             ComboBox 樣式
        ═══════════════════════════════════════════ -->
        <Style x:Key="JapaneseComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineGrayBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource SumiBlackBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <!-- ═══════════════════════════════════════════
             食物類別 Label 樣式
        ═══════════════════════════════════════════ -->
        <Style x:Key="CategoryLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource ChikuGreenBrush}"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <!-- ═══════════════════════════════════════════
             IntegerUpDown 樣式
        ═══════════════════════════════════════════ -->
        <Style x:Key="JapaneseIntUpDown" TargetType="xctk:IntegerUpDown">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineGrayBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource SumiBlackBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ═══════════════════════════════════════════
             食品行項 Hover 樣式 (Border)
        ═══════════════════════════════════════════ -->
        <Style x:Key="FoodItemBorder" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════
         根佈局：垂直三段 (Header / Body)
    ═══════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Body -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════
             HEADER 頂部標題列
        ════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource SumiBlackBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 店名 -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="28,0,0,0">
                    <!-- 竹節裝飾線 -->
                    <Border Width="3" Height="22"
                            Background="{StaticResource ChikuGreenBrush}"
                            CornerRadius="1.5"
                            Margin="0,0,12,0"/>
                    <TextBlock Text="御膳"
                               FontSize="20"
                               FontWeight="Light"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="GOZEN POS"
                               FontSize="11"
                               Foreground="#888880"
                               VerticalAlignment="Center"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- 右側：優惠券 + 總金額 -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,28,0">

                    <!-- 優惠券選擇 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                        <TextBlock Text="優惠券"
                                   FontSize="11"
                                   Foreground="#888880"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ComboBox Name="CuponComboBox"
                                  Width="160"
                                  Style="{StaticResource JapaneseComboBox}"
                                  DisplayMemberPath="Type"
                                  ItemsSource="{Binding Discounts}"
                                  SelectedItem="{Binding SelectedCupon}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="SelectCupon">
                                    <i:InvokeCommandAction
                                        Command="{Binding DataContext.SelectCuponCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </ComboBox>
                    </StackPanel>

                    <!-- 分隔線 -->
                    <Border Width="1" Height="24" Background="#3A3A3A" Margin="0,0,24,0"/>

                    <!-- 總金額 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="總計"
                                   FontSize="11"
                                   Foreground="#888880"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="$"
                                   FontSize="13"
                                   Foreground="{StaticResource AccentGoldBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,2,0"/>
                        <TextBlock Text="{Binding TotalPay}"
                                   FontSize="22"
                                   FontWeight="Light"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════
             BODY 主體區域：三欄
        ════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>    <!-- 左：菜單 -->
                <ColumnDefinition Width="1"/>      <!-- 分隔 -->
                <ColumnDefinition Width="*"/>      <!-- 中：訂單明細 -->
                <ColumnDefinition Width="1"/>      <!-- 分隔 -->
                <ColumnDefinition Width="280"/>    <!-- 右：AI推薦 -->
            </Grid.ColumnDefinitions>

            <!-- ────────────────────────────
                 左欄：菜單選項
            ──────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource WashiWhiteBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 欄位標題 -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource LineGrayBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="24,14">
                        <TextBlock Text="菜　單"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SumiBlackBrush}"/>
                    </Border>

                    <!-- 菜單列表 -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="20,8,20,20">
                        <ItemsControl ItemsSource="{Binding Menus}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,16">

                                        <!-- 類別標題 + 裝飾線 -->
                                        <Grid Margin="0,8,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding FoodType}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource ChikuGreenBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <Border Grid.Column="1"
                                                    Height="1"
                                                    Background="{StaticResource LineGrayBrush}"
                                                    VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- 食品項目列表 -->
                                        <ItemsControl ItemsSource="{Binding Foods}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource FoodItemBorder}"
                                                            Margin="0,1">
                                                        <Grid Height="36">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="60"/>
                                                                <ColumnDefinition Width="68"/>
                                                            </Grid.ColumnDefinitions>

                                                            <CheckBox Grid.Column="0"
                                                                      Style="{StaticResource JapaneseCheckBox}"
                                                                      Margin="2,0,8,0"
                                                                      VerticalAlignment="Center"
                                                                      Command="{Binding DataContext.CheckChangeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      CommandParameter="{Binding}"
                                                                      IsChecked="{Binding IsChecked}"/>

                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Name}"
                                                                       FontSize="13"
                                                                       Foreground="{StaticResource SumiBlackBrush}"
                                                                       VerticalAlignment="Center"/>

                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding Price, StringFormat=¥{0}}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource InkGrayBrush}"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Right"
                                                                       Margin="0,0,8,0"/>

                                                            <xctk:IntegerUpDown
                                                                x:Name="FoodValue"
                                                                Grid.Column="3"
                                                                Width="60"
                                                                Height="26"
                                                                Style="{StaticResource JapaneseIntUpDown}"
                                                                Minimum="0"
                                                                Value="{Binding Quality}">
                                                                <i:Interaction.Triggers>
                                                                    <i:EventTrigger EventName="ValueChanged">
                                                                        <i:InvokeCommandAction
                                                                            Command="{Binding DataContext.ValueChangeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding}"/>
                                                                    </i:EventTrigger>
                                                                </i:Interaction.Triggers>
                                                            </xctk:IntegerUpDown>

                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 分隔線 -->
            <Border Grid.Column="1" Background="{StaticResource LineGrayBrush}"/>

            <!-- ────────────────────────────
                 中欄：訂單明細
            ──────────────────────────── -->
            <Border Grid.Column="2"
                    Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 欄位標題 -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource LineGrayBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="24,14">
                        <TextBlock Text="消費明細"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SumiBlackBrush}"/>
                    </Border>

                    <!-- AI推薦開關 -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BambooCreamBrush}"
                            BorderBrush="{StaticResource LineGrayBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="24,10">
                        <CheckBox Style="{StaticResource JapaneseCheckBox}"
                                  Content="啟用 AI 自動推薦優惠"
                                  FontSize="12"
                                  Foreground="{StaticResource InkGrayBrush}"
                                  Command="{Binding DataContext.IsAICheckedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  IsChecked="{Binding AIchecked}"/>
                    </Border>

                    <!-- 明細內容 (ContentControl → MenuPanel UserControl) -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0">
                        <ContentControl Content="{Binding MenuPanel}"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 分隔線 -->
            <Border Grid.Column="3" Background="{StaticResource LineGrayBrush}"/>

            <!-- ────────────────────────────
                 右欄：AI 推薦原因
            ──────────────────────────── -->
            <Border Grid.Column="4"
                    Background="{StaticResource WashiWhiteBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 欄位標題 -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource LineGrayBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="20,14">
                        <StackPanel Orientation="Horizontal">
                            <!-- 小圓點裝飾 -->
                            <Ellipse Width="6" Height="6"
                                     Fill="{StaticResource ChikuGreenBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"/>
                            <TextBlock Text="AI　推薦"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SumiBlackBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- 推薦文字 -->
                    <Border Grid.Row="1" Padding="20,16">
                        <TextBlock Text="{Binding reason}"
                                   FontSize="13"
                                   LineHeight="22"
                                   Foreground="{StaticResource InkGrayBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Top"/>
                    </Border>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
